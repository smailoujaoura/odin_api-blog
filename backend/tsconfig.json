{
  "compilerOptions": {
    "target": "ES2022",          // modern JS
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,     // allow import express from "express"
    "skipLibCheck": true
  },
  "include": ["src"]
}
